# Copy to .env.local for local development. Both variables are also required
# in the Vercel project settings (they're inlined at build time).

# 8-character form ID from your Formspree form's endpoint URL
# (https://formspree.io/f/<THIS PART>). Optional: the production form's ID
# (mykadjwp) is the baked-in default; set this only to override it,
# e.g. to point a test deployment at a different form.
NEXT_PUBLIC_FORMSPREE_ID=

# Public URL of the deployed site, used for Open Graph / link-preview
# metadata. E.g. https://classic.onehouseproject.com
NEXT_PUBLIC_SITE_URL=
